package coffee

import (
	"tangled.org/arabica.social/arabica/internal/entities/arabica"
	. "tangled.org/arabica.social/arabica/internal/web/components"
)

// GrinderContent renders grinder details inside a card
templ GrinderContent(grinder *arabica.Grinder) {
	<div class="feed-content-box-sm">
		<div class="text-base mb-2">
			<span class="font-bold text-primary">{ grinder.Name }</span>
		</div>
		<div class="text-xs text-muted mt-1 flex flex-wrap gap-x-2 gap-y-1">
			if grinder.GrinderType != "" {
				<span class="inline-flex items-center gap-1">
					@IconTag()
					{ grinder.GrinderType }
				</span>
			}
			if grinder.BurrType != "" {
				<span class="inline-flex items-center gap-1">
					@IconDisc()
					{ grinder.BurrType }
				</span>
			}
		</div>
		if grinder.Notes != "" {
			<div class="mt-2 text-sm text-secondary italic">"{ grinder.Notes }"</div>
		}
	</div>
}
