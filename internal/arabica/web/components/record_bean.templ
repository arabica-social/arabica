package coffee

import (
	"tangled.org/arabica.social/arabica/internal/entities/arabica"
	. "tangled.org/arabica.social/arabica/internal/web/components"
)

// BeanContent renders bean details inside a card
templ BeanContent(bean *arabica.Bean) {
	<div class="feed-content-box-sm">
		@BeanSummary(BeanSummaryProps{
			Bean: bean,
		})
		if bean.Description != "" {
			<div class="mt-2 text-sm text-secondary italic">"{ bean.Description }"</div>
		}
	</div>
}
