				value={ getStringValue(roaster, "website") }
				placeholder="Website"
				class="w-full form-input"
			/>
		</div>
	}
}

// recipePourJSON returns a JSON array string of existing pours for Alpine.js init.
func recipePourJSON(recipe *arabica.Recipe) string {
	if recipe == nil || len(recipe.Pours) == 0 {
		return "[]"
	}
	var parts []string
	for _, p := range recipe.Pours {
		parts = append(parts, fmt.Sprintf("{water: %d, time: %d}", p.WaterAmount, p.TimeSeconds))
	}
	return "[" + strings.Join(parts, ", ") + "]"
}

// RecipeDialogModal renders the recipe creation/edit modal using native <dialog>
templ RecipeDialogModal(recipe *arabica.Recipe, brewers []arabica.Brewer) {
	@ModalShell(ModalShellProps{
		Type:       lexicons.RecordTypeRecipe,
		RKey:       modalEntityRKey(recipe),
		ExtraXData: fmt.Sprintf("{ serverError: '', pours: %s, addPour() { this.pours.push({water: '', time: ''}); }, removePour(i) { this.pours.splice(i, 1); } }", recipePourJSON(recipe)),
	}) {
		<!-- Essentials -->
		<div class="form-fieldset">
			<div class="form-fieldset-label">Essentials</div>
			<input
				type="text"
				name="name"
				value={ getStringValue(recipe, "name") }
				placeholder="Name *"
				required
				class="w-full form-input"
			/>
			<select
				name="brewer_rkey"
				class="w-full form-input"
			>
				<option value="">Select Brewer</option>
				for _, brewer := range brewers {
					<option
						value={ brewer.RKey }
						if recipe != nil && recipe.BrewerRKey == brewer.RKey {
							selected
						}
					>
						{ brewer.Name }
					</option>
				}
			</select>
			<input
				type="text"
				name="brewer_type"
				value={ getStringValue(recipe, "brewer_type") }
				placeholder="Brewer Type (e.g., Pour-Over, Immersion)"
				class="w-full form-input"
			/>
		</div>
		<div class="form-divider"></div>
		<!-- Amounts -->
		<div class="form-fieldset">
			<div class="form-fieldset-label">Amounts <span class="form-optional-hint">(optional)</span></div>
			<div class="grid grid-cols-2 gap-3">
				<input
					type="number"
					name="coffee_amount"
					value={ getStringValue(recipe, "coffee_amount") }
					placeholder="Coffee (g)"
					step="0.1"
					class="w-full form-input"
				/>
				<input
					type="number"
					name="water_amount"
					value={ getStringValue(recipe, "water_amount") }
					placeholder="Water (g)"
					step="0.1"
					class="w-full form-input"
				/>
			</div>
		</div>
		<div class="form-divider"></div>
		<!-- Pours -->
		<div class="form-fieldset">
			<div class="flex items-center justify-between">
				<div class="form-fieldset-label">Pours <span class="form-optional-hint">(optional)</span></div>
				<button
					type="button"
					@click="addPour()"
					class="text-sm btn-secondary"
				>
					+ Add Pour
				</button>
			</div>
			<div class="space-y-2">
				<template x-for="(pour, index) in pours" :key="index">
					<div class="flex gap-2 items-center p-3 rounded-lg" style="background: var(--surface-bg); border: 1px solid var(--surface-border);">
						<div class="flex-1">
							<label class="text-xs text-emphasis font-medium" x-text="'Pour ' + (index + 1)"></label>
							<input
								type="number"
								:name="'pour_water_' + index"
								x-model="pour.water"
								placeholder="Water (g)"
								class="w-full form-input text-sm py-2 px-3 mt-1"
							/>
						</div>
						<div class="flex-1">
							<label class="text-xs text-emphasis font-medium">Time (sec)</label>
							<input
								type="number"
								:name="'pour_time_' + index"
								x-model="pour.time"
								placeholder="e.g. 45"
								class="w-full form-input text-sm py-2 px-3 mt-1"
							/>
						</div>
						<button
							type="button"
							@click="removePour(index)"
							class="text-emphasis hover:text-primary mt-5 font-bold"
						>
							@IconX()
						</button>
					</div>
				</template>
			</div>
		</div>
		<div class="form-divider"></div>
		<!-- Notes -->
		<div class="form-fieldset">
			<div class="form-fieldset-label">Notes <span class="form-optional-hint">(optional)</span></div>
			<textarea
				name="notes"
				placeholder="Notes"
				rows="3"
				class="w-full form-textarea"
			>{ getStringValue(recipe, "notes") }</textarea>
		</div>
	}
}

// roasterPickerInit generates Alpine.js x-data for the inline roaster picker.
func roasterPickerInit(bean *arabica.Bean, roasters []arabica.Roaster) string {
	// Build JSON array of roasters for Alpine
	var items []string
	for _, r := range roasters {
		items = append(items, fmt.Sprintf(`{rkey:'%s',name:'%s'}`, r.RKey, strings.ReplaceAll(r.Name, "'", "\\'")))
	}
	allRoasters := "[" + strings.Join(items, ",") + "]"

	// Pre-select if editing a bean with a roaster
	selectedRKey := ""
	selectedName := ""
	if bean != nil && bean.RoasterRKey != "" {
		selectedRKey = bean.RoasterRKey
		if bean.Roaster != nil {
			selectedName = strings.ReplaceAll(bean.Roaster.Name, "'", "\\'")
		} else {
			// Find name from roasters list
			for _, r := range roasters {
				if r.RKey == bean.RoasterRKey {
					selectedName = strings.ReplaceAll(r.Name, "'", "\\'")
					break
				}
			}
		}
	}

	return fmt.Sprintf(`{
		allRoasters: %s,
		filtered: %s,
		query: '%s',
		selectedRKey: '%s',
		newRoasterName: '',
		newRoasterLocation: '',
		newRoasterWebsite: '',
		showDropdown: false,
		showDetails: false,
		get exactMatch() {
			const q = this.query.trim().toLowerCase();
			return this.allRoasters.some(r => r.name.toLowerCase() === q);
		},
		filter() {
			const q = this.query.trim().toLowerCase();
			this.selectedRKey = '';
			this.newRoasterName = '';
			if (!q) { this.filtered = this.allRoasters.slice(0, 10); return; }
			this.filtered = this.allRoasters.filter(r => r.name.toLowerCase().includes(q));
		},
		selectRoaster(r) {
			this.selectedRKey = r.rkey;
			this.newRoasterName = '';
			this.newRoasterLocation = '';
			this.newRoasterWebsite = '';
			this.query = r.name;
			this.showDropdown = false;
			this.showDetails = false;
		},
		startCreate() {
			this.newRoasterName = this.query.trim();
			this.selectedRKey = '';
			this.showDropdown = false;
			this.showDetails = true;
		},
		cancelCreate() {
			this.newRoasterName = '';
			this.newRoasterLocation = '';
			this.newRoasterWebsite = '';
			this.showDetails = false;
		},
		clear() {
			this.query = '';
			this.selectedRKey = '';
			this.newRoasterName = '';
			this.newRoasterLocation = '';
			this.newRoasterWebsite = '';
			this.showDetails = false;
			this.filtered = this.allRoasters.slice(0, 10);
		}
	}`, allRoasters, allRoasters, selectedName, selectedRKey)
}

// beanRatingInitData returns Alpine.js x-data for the rating toggle.
// If bean has a rating, the slider is shown with that value; otherwise hidden.
func beanRatingInitData(bean *arabica.Bean) string {
	if bean != nil && bean.Rating != nil {
		return fmt.Sprintf("{ showRating: true, rating: %d }", *bean.Rating)
	}
	return "{ showRating: false, rating: 0 }"
}

func getStringValue(entity interface{}, field string) string {
	if entity == nil {
		return ""
	}
	rt := recordTypeOf(entity)
	d := entities.Get(rt)
	if d == nil || d.GetField == nil {
		return ""
	}
	v, _ := d.GetField(entity, field)
	return v
}

// modalEntityRKey extracts the record key from any of the typed model
// pointers used as modal arguments. Returns "" for nil or unknown types,
// which the modal shell interprets as "create" (POST) instead of "edit".
func modalEntityRKey(entity any) string {
	switch e := entity.(type) {
	case *arabica.Bean:
		if e != nil {
			return e.RKey
		}
	case *arabica.Roaster:
		if e != nil {
			return e.RKey
		}
	case *arabica.Grinder:
		if e != nil {
			return e.RKey
		}
	case *arabica.Brewer:
		if e != nil {
			return e.RKey
		}
	case *arabica.Recipe:
		if e != nil {
			return e.RKey
		}
	}
	return ""
}

// recordTypeOf maps a typed model pointer to its RecordType. Local helper
// because callers here hold a typed pointer; moving this onto the model
// is deferred to phase 4.
func recordTypeOf(entity any) lexicons.RecordType {
	switch entity.(type) {
	case *arabica.Bean:
		return lexicons.RecordTypeBean
	case *arabica.Roaster:
		return lexicons.RecordTypeRoaster
	case *arabica.Grinder:
		return lexicons.RecordTypeGrinder
	case *arabica.Brewer:
		return lexicons.RecordTypeBrewer
	case *arabica.Recipe:
		return lexicons.RecordTypeRecipe
	}
	return ""
}
