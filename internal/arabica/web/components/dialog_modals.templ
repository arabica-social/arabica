package coffee

import (
	"fmt"
	"strings"
	"tangled.org/arabica.social/arabica/internal/entities"
	"tangled.org/arabica.social/arabica/internal/entities/arabica"
	"tangled.org/arabica.social/arabica/internal/lexicons"
	. "tangled.org/arabica.social/arabica/internal/web/components"
)

// DialogModalProps defines properties for a native HTML5 dialog modal
type DialogModalProps struct {
	ID    string // Dialog ID (e.g., "bean-modal")
	Title string
}

// BeanDialogModal renders the bean creation/edit modal using native <dialog>
templ BeanDialogModal(bean *arabica.Bean, roasters []arabica.Roaster) {
	@ModalShell(ModalShellProps{
		Type: lexicons.RecordTypeBean,
		RKey: modalEntityRKey(bean),
	}) {
		<!-- Essentials -->
		<div class="form-fieldset">
			<div class="form-fieldset-label">Essentials</div>
			if bean == nil {
				<div x-data="entitySuggest('/api/suggestions/beans')" class="relative">
					<input
						type="text"
						name="name"
						placeholder="Name *"
						required
						class="w-full form-input"
						x-model="query"
						@input.debounce.300ms="search()"
						@blur.debounce.200ms="showSuggestions = false"
						@focus="if (suggestions.length > 0) showSuggestions = true"
						autocomplete="off"
					/>
					<input type="hidden" name="source_ref" x-model="sourceRef"/>
					<template x-if="showSuggestions && suggestions.length > 0">
						<div class="suggestions-dropdown">
							<template x-for="s in suggestions" :key="s.source_uri">
								<button
									type="button"
									class="suggestions-item"
									@mousedown.prevent="selectBeanSuggestion(s)"
								>
									<span class="font-medium" x-text="s.name"></span>
									<template x-if="s.fields.origin">
										<span class="text-xs text-faint" x-text="s.fields.origin"></span>
									</template>
									<template x-if="s.count > 1">
										<span class="text-xs text-placeholder" x-text="s.count + ' users'"></span>
									</template>
								</button>
							</template>
						</div>
					</template>
				</div>
			} else {
				<input
					type="text"
					name="name"
					value={ getStringValue(bean, "name") }
					placeholder="Name *"
					required
					class="w-full form-input"
				/>
			}
			<input
				type="text"
				name="origin"
				value={ getStringValue(bean, "origin") }
				placeholder="Origin *"
				required
				class="w-full form-input"
			/>
		</div>
		<div class="form-divider"></div>
		<!-- Origin details -->
		<div class="form-fieldset">
			<div class="form-fieldset-label">Origin Details <span class="form-optional-hint">(optional)</span></div>
			<input
				type="text"
				name="variety"
				value={ getStringValue(bean, "variety") }
				placeholder="Variety (e.g. SL28, Typica, Gesha)"
				class="w-full form-input"
			/>
			<div x-data={ roasterPickerInit(bean, roasters) } class="relative">
				<input
					type="text"
					x-model="query"
					x-show="!showDetails"
					@input="filter()"
					@focus="showDropdown = true"
					@blur="setTimeout(() => showDropdown = false, 150)"
					@keydown.escape.prevent="showDropdown = false"
					placeholder="Search or create roaster"
					class="w-full form-input"
					autocomplete="off"
				/>
				<input type="hidden" name="roaster_rkey" :value="selectedRKey"/>
				<input type="hidden" name="new_roaster_name" :value="newRoasterName"/>
				<input type="hidden" name="new_roaster_location" :value="newRoasterLocation"/>
				<input type="hidden" name="new_roaster_website" :value="newRoasterWebsite"/>
				<button
					type="button"
					x-show="(selectedRKey || newRoasterName) && !showDetails"
					@click="clear()"
					class="absolute right-2 top-1/2 -translate-y-1/2 text-placeholder hover:text-muted text-sm"
					x-cloak
				>
					&times;
				</button>
				<div x-show="showDropdown && !showDetails" x-cloak class="absolute z-10 w-full mt-1 max-h-48 overflow-y-auto rounded-lg shadow-lg" style="background: var(--card-bg, #fff); border: 1px solid var(--surface-border, #d4c4a8);">
					<template x-for="r in filtered" :key="r.rkey">
						<div
							class="px-3 py-2 cursor-pointer text-sm hover:bg-brown-100"
							@mousedown.prevent="selectRoaster(r)"
							x-text="r.name"
						></div>
					</template>
					<template x-if="query.trim() && !exactMatch">
						<div
							class="px-3 py-2 cursor-pointer text-sm font-medium border-t hover:bg-brown-100"
							style="border-color: var(--surface-border, #d4c4a8);"
							@mousedown.prevent="startCreate()"
						>
							Create "<span x-text="query.trim()"></span>"
						</div>
					</template>
				</div>
				<!-- Inline details for new roaster -->
				<div x-show="showDetails" x-transition x-cloak class="p-3 rounded-lg space-y-2" style="background: var(--surface-bg); border: 1px solid var(--surface-border);">
					<p class="text-sm font-medium text-primary">
						New roaster: <span x-text="newRoasterName" class="font-semibold"></span>
					</p>
					<input
						type="text"
						x-model="newRoasterLocation"
						placeholder="Location (optional)"
						class="w-full form-input text-sm"
					/>
					<input
						type="url"
						x-model="newRoasterWebsite"
						placeholder="Website (optional)"
						class="w-full form-input text-sm"
					/>
					<button
						type="button"
						@click="cancelCreate()"
						class="text-xs text-faint hover:text-emphasis"
					>
						Cancel
					</button>
				</div>
			</div>
			<select
				name="roast_level"
				class="w-full form-input"
			>
				<option value="">Select Roast Level</option>
				for _, level := range arabica.RoastLevels {
					<option
						value={ level }
						if bean != nil && bean.RoastLevel == level {
							selected
						}
					>
						{ level }
					</option>
				}
			</select>
			<input
				type="text"
				name="process"
				value={ getStringValue(bean, "process") }
				placeholder="Process (e.g. Washed, Natural, Honey)"
				class="w-full form-input"
			/>
		</div>
		<div class="form-divider"></div>
		<!-- Notes & rating -->
		<div class="form-fieldset">
			<div class="form-fieldset-label">Notes & Rating <span class="form-optional-hint">(optional)</span></div>
			<textarea
				name="description"
				placeholder="Description"
				rows="3"
				class="w-full form-textarea"
			>{ getStringValue(bean, "description") }</textarea>
			<div x-data={ beanRatingInitData(bean) }>
				<div x-show="!showRating">
					<button
						type="button"
						@click="showRating = true; if (rating === 0) rating = 5"
						class="text-sm font-medium text-emphasis hover:text-primary flex items-center gap-1"
					>
						@IconStar()
						Add Rating
					</button>
				</div>
				<div x-show="showRating" x-transition class="space-y-2">
					<div class="flex items-center justify-between">
						<label class="form-label mb-0">Rating</label>
						<button
							type="button"
							@click="showRating = false; rating = 0"
							class="text-xs text-faint hover:text-emphasis"
						>
							Remove rating
						</button>
					</div>
					<input
						type="range"
						min="1"
						max="10"
						x-model.number="rating"
						class="w-full accent-brown-700"
					/>
					<div class="text-center text-2xl font-bold text-secondary">
						<span x-text="rating"></span>/10
					</div>
					<input type="hidden" name="rating" :value="showRating ? rating : ''"/>
				</div>
			</div>
		</div>
		// Only show "close bag check" when editing
		if bean != nil {
			<div class="form-divider"></div>
			<div class="flex items-center gap-2">
				<input
					type="checkbox"
					name="closed"
					value="true"
					id="bean-closed-checkbox-modal"
					if bean != nil && bean.Closed {
						checked
					}
					class="rounded-sm border-brown-300 text-emphasis focus:ring-brown-500"
				/>
				<label for="bean-closed-checkbox-modal" class="text-sm text-primary">
					Bag is closed/finished
				</label>
			</div>
		}
	}
}

// GrinderDialogModal renders the grinder creation/edit modal using native <dialog>
templ GrinderDialogModal(grinder *arabica.Grinder) {
	@ModalShell(ModalShellProps{
		Type: lexicons.RecordTypeGrinder,
		RKey: modalEntityRKey(grinder),
	}) {
		<!-- Essentials -->
		<div class="form-fieldset">
			<div class="form-fieldset-label">Essentials</div>
			if grinder == nil {
				<div x-data="entitySuggest('/api/suggestions/grinders')" class="relative">
					<input
						type="text"
						name="name"
						placeholder="Name *"
						required
						class="w-full form-input"
						x-model="query"
						@input.debounce.300ms="search()"
						@blur.debounce.200ms="showSuggestions = false"
						@focus="if (suggestions.length > 0) showSuggestions = true"
						autocomplete="off"
					/>
					<input type="hidden" name="source_ref" x-model="sourceRef"/>
					<template x-if="showSuggestions && suggestions.length > 0">
						<div class="suggestions-dropdown">
							<template x-for="s in suggestions" :key="s.source_uri">
								<button
									type="button"
									class="suggestions-item"
									@mousedown.prevent="selectGrinderSuggestion(s)"
								>
									<span class="font-medium" x-text="s.name"></span>
									<template x-if="s.fields.grinderType">
										<span class="text-xs text-faint" x-text="s.fields.grinderType"></span>
									</template>
									<template x-if="s.count > 1">
										<span class="text-xs text-placeholder" x-text="s.count + ' users'"></span>
									</template>
								</button>
							</template>
						</div>
					</template>
				</div>
			} else {
				<input
					type="text"
					name="name"
					value={ getStringValue(grinder, "name") }
					placeholder="Name *"
					required
					class="w-full form-input"
				/>
			}
			<select
				name="grinder_type"
				class="w-full form-input"
				required
			>
				<option value="">Select Grinder Type *</option>
				for _, gType := range arabica.GrinderTypes {
					<option
						value={ gType }
						if grinder != nil && grinder.GrinderType == gType {
							selected
						}
					>
						{ gType }
					</option>
				}
			</select>
		</div>
		<div class="form-divider"></div>
		<!-- Details -->
		<div class="form-fieldset">
			<div class="form-fieldset-label">Details <span class="form-optional-hint">(optional)</span></div>
			<select
				name="burr_type"
				class="w-full form-input"
			>
				<option value="">Select Burr Type</option>
				for _, bType := range arabica.BurrTypes {
					<option
						value={ bType }
						if grinder != nil && grinder.BurrType == bType {
							selected
						}
					>
						{ bType }
					</option>
				}
			</select>
			<textarea
				name="notes"
				placeholder="Notes"
				rows="3"
				class="w-full form-textarea"
			>{ getStringValue(grinder, "notes") }</textarea>
		</div>
	}
}

// BrewerDialogModal renders the brewer creation/edit modal using native <dialog>
templ BrewerDialogModal(brewer *arabica.Brewer) {
	@ModalShell(ModalShellProps{
		Type: lexicons.RecordTypeBrewer,
		RKey: modalEntityRKey(brewer),
	}) {
		<!-- Essentials -->
		<div class="form-fieldset">
			<div class="form-fieldset-label">Essentials</div>
			if brewer == nil {
				<div x-data="entitySuggest('/api/suggestions/brewers')" class="relative">
					<input
						type="text"
						name="name"
						placeholder="Name *"
						required
						class="w-full form-input"
						x-model="query"
						@input.debounce.300ms="search()"
						@blur.debounce.200ms="showSuggestions = false"
						@focus="if (suggestions.length > 0) showSuggestions = true"
						autocomplete="off"
					/>
					<input type="hidden" name="source_ref" x-model="sourceRef"/>
					<template x-if="showSuggestions && suggestions.length > 0">
						<div class="suggestions-dropdown">
							<template x-for="s in suggestions" :key="s.source_uri">
								<button
									type="button"
									class="suggestions-item"
									@mousedown.prevent="selectBrewerSuggestion(s)"
								>
									<span class="font-medium" x-text="s.name"></span>
									<template x-if="s.fields.brewerType">
										<span class="text-xs text-faint" x-text="s.fields.brewerType"></span>
									</template>
									<template x-if="s.count > 1">
										<span class="text-xs text-placeholder" x-text="s.count + ' users'"></span>
									</template>
								</button>
							</template>
						</div>
					</template>
				</div>
			} else {
				<input
					type="text"
					name="name"
					value={ getStringValue(brewer, "name") }
					placeholder="Name *"
					required
					class="w-full form-input"
				/>
			}
			<select
				name="brewer_type"
				class="w-full form-select"
			>
				<option value="">Select type...</option>
				<option
					value="pourover"
					if getStringValue(brewer, "brewer_type") == "pourover" || arabica.NormalizeBrewerType(getStringValue(brewer, "brewer_type")) == "pourover" {
						selected
					}
				>Pour-over</option>
				<option
					value="espresso"
					if getStringValue(brewer, "brewer_type") == "espresso" || arabica.NormalizeBrewerType(getStringValue(brewer, "brewer_type")) == "espresso" {
						selected
					}
				>Espresso</option>
				<option
					value="immersion"
					if getStringValue(brewer, "brewer_type") == "immersion" || arabica.NormalizeBrewerType(getStringValue(brewer, "brewer_type")) == "immersion" {
						selected
					}
				>Immersion</option>
				<option
					value="mokapot"
					if getStringValue(brewer, "brewer_type") == "mokapot" || arabica.NormalizeBrewerType(getStringValue(brewer, "brewer_type")) == "mokapot" {
						selected
					}
				>Moka Pot</option>
				<option
					value="coldbrew"
					if getStringValue(brewer, "brewer_type") == "coldbrew" || arabica.NormalizeBrewerType(getStringValue(brewer, "brewer_type")) == "coldbrew" {
						selected
					}
				>Cold Brew</option>
				<option
					value="cupping"
					if getStringValue(brewer, "brewer_type") == "cupping" || arabica.NormalizeBrewerType(getStringValue(brewer, "brewer_type")) == "cupping" {
						selected
					}
				>Cupping</option>
				<option
					value="other"
					if getStringValue(brewer, "brewer_type") == "other" || arabica.NormalizeBrewerType(getStringValue(brewer, "brewer_type")) == "other" {
						selected
					}
				>Other</option>
			</select>
		</div>
		<div class="form-divider"></div>
		<!-- Description -->
		<div class="form-fieldset">
			<div class="form-fieldset-label">Description <span class="form-optional-hint">(optional)</span></div>
			<textarea
				name="description"
				placeholder="Description"
				rows="3"
				class="w-full form-textarea"
			>{ getStringValue(brewer, "description") }</textarea>
		</div>
	}
}

// RoasterDialogModal renders the roaster creation/edit modal using native <dialog>
templ RoasterDialogModal(roaster *arabica.Roaster) {
	@ModalShell(ModalShellProps{
		Type: lexicons.RecordTypeRoaster,
		RKey: modalEntityRKey(roaster),
	}) {
		<!-- Essentials -->
		<div class="form-fieldset">
