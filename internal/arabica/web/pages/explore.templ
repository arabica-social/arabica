package coffeepages

import (
	"fmt"
	"net/url"

	coffeecomponents "tangled.org/arabica.social/arabica/internal/arabica/web/components"
	"tangled.org/arabica.social/arabica/internal/feed"
	"tangled.org/arabica.social/arabica/internal/firehose"
	"tangled.org/arabica.social/arabica/internal/lexicons"
	"tangled.org/arabica.social/arabica/internal/web/components"
)

type ExploreProps struct {
	Query       firehose.ExploreQuery
	Result      *firehose.ExploreResult
	Health      firehose.ExploreHealth
	FilterNames []string
	RoutePaths  map[lexicons.RecordType]string
}

templ ExplorePage(layout *components.LayoutData, props ExploreProps) {
	@components.Layout(layout, ExploreContent(props))
}

templ ExploreContent(props ExploreProps) {
	<section class="explore-page">
		<header class="explore-hero">
			<div class="explore-hero-copy">
				<p class="explore-eyebrow">Community library</p>
				<h1 class="explore-title">Explore records.</h1>
				<p class="explore-lede">Find beans, roasters, gear, and recipes.</p>
			</div>
			if props.Health.Dirty {
				<div class="explore-stale-note" role="status" aria-live="polite">
					Explore is catching up. Results may be slightly stale.
				</div>
			}
		</header>
		@ExploreInteractive(props)
	</section>
	<!-- Return to top button -->
	<div v-scope="ScrollTop()" @vue:mounted="setup">
		<button
			:class="{ 'is-visible': visible }"
			@click="scrollTop"
			class="scroll-top-btn fixed bottom-6 right-6 z-50 bg-brown-800 text-brown-50 rounded-full shadow-lg hover:bg-brown-700 transition-colors cursor-pointer p-3 sm:px-4 sm:py-2.5 sm:rounded-lg flex items-center gap-2"
			aria-label="Return to top"
		>
			<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
				<path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd"></path>
			</svg>
			<span class="hidden sm:inline text-sm font-medium">Back to top</span>
		</button>
	</div>
}

templ ExploreInteractive(props ExploreProps) {
	<div id="explore-interactive" class="space-y-6">
		<details class="explore-controls" open?={ hasExploreControls(props) }>
			<summary class="explore-controls-summary cursor-pointer">
				<span class="explore-controls-title">
					<span class="block text-sm font-semibold text-primary">Search and filters</span>
				</span>
				<span class="explore-controls-count badge">{ exploreActiveLabel(props) }</span>
			</summary>
			<form
				method="GET"
				action="/explore"
				class="explore-controls-form space-y-4"
				hx-get="/explore"
				hx-target="#explore-interactive"
				hx-select="#explore-interactive"
				hx-swap="outerHTML"
				hx-push-url="true"
			>
				<div class="explore-primary-filters grid grid-cols-1 gap-3 items-end">
					<label class="block">
						<span class="block text-sm font-medium text-muted mb-1">Search</span>
						<input class="form-input w-full" type="search" name="q" value={ props.Query.Q } placeholder="Ethiopia, V60, washed"/>
					</label>
					<label class="block">
						<span class="block text-sm font-medium text-muted mb-1">Type</span>
						<select class="form-select w-full" name="type">
							<option value="" selected?={ props.Query.Type == "" }>All records</option>
							@typeOption(props.Query.Type, lexicons.RecordTypeBean, "Beans")
							@typeOption(props.Query.Type, lexicons.RecordTypeRoaster, "Roasters")
							@typeOption(props.Query.Type, lexicons.RecordTypeGrinder, "Grinders")
							@typeOption(props.Query.Type, lexicons.RecordTypeBrewer, "Brewers")
							@typeOption(props.Query.Type, lexicons.RecordTypeRecipe, "Recipes")
						</select>
					</label>
					<label class="block">
						<span class="block text-sm font-medium text-muted mb-1">Sort</span>
						<select class="form-select w-full" name="sort">
							<option value="recent" selected?={ props.Query.Sort == "" || props.Query.Sort == "recent" }>Recent</option>
							<option value="popular" selected?={ props.Query.Sort == "popular" }>Popular</option>
							<option value="rating_high" selected?={ props.Query.Sort == "rating_high" }>Rating high</option>
						</select>
					</label>
				</div>
				<details class="explore-advanced-filters" open?={ hasAdvancedFilters(props) }>
					<summary class="text-sm font-medium text-emphasis cursor-pointer">Advanced filters</summary>
					<div class="explore-filter-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
						@filterInput(props, "origin", "Origin", "Ethiopia, Colombia, Kenya…")
						@filterInput(props, "roaster", "Roaster", "Onyx, Sey, Heart…")
						@filterInput(props, "roast_level", "Roast level", "Light, medium, dark…")
						@filterInput(props, "process", "Process", "Washed, natural, honey…")
						@filterInput(props, "variety", "Variety", "Bourbon, Gesha, Caturra…")
						@filterInput(props, "location", "Location", "Portland, Tokyo, London…")
						@filterInput(props, "grinder_type", "Grinder type", "Hand, electric…")
						@filterInput(props, "burr_type", "Burr type", "Conical, flat…")
						@filterInput(props, "brewer_type", "Brewer type", "V60, espresso, aeropress…")
						@filterInput(props, "min_rating", "Minimum rating", "8")
						@filterInput(props, "ratio_min", "Ratio min", "15")
						@filterInput(props, "ratio_max", "Ratio max", "17")
						<label class="block">
							<span class="block text-sm font-medium text-muted mb-1">Closed beans</span>
							<select class="form-select w-full" name="closed">
								<option value="" selected?={ selectedFilter(props, "closed") == "" }>Any</option>
								<option value="true" selected?={ selectedFilter(props, "closed") == "true" }>Closed</option>
								<option value="false" selected?={ selectedFilter(props, "closed") == "false" }>Open</option>
							</select>
						</label>
					</div>
				</details>
				<div class="flex flex-wrap gap-2 items-center">
					<button class="btn-primary" type="submit">Explore</button>
					<a class="btn-secondary" href="/explore" hx-get="/explore" hx-target="#explore-interactive" hx-select="#explore-interactive" hx-swap="outerHTML" hx-push-url="true">Clear</a>
					if props.Result != nil {
						<span class="text-sm text-muted ml-auto">{ fmt.Sprintf("%d shown", len(props.Result.Items)) }</span>
					}
				</div>
			</form>
		</details>
		if props.Result == nil || len(props.Result.Items) == 0 {
			<div class="explore-empty">
				@components.EmptyState(components.EmptyStateProps{Message: "No matching records yet.", SubMessage: "Try fewer filters, or come back after the witness cache sees more community records."})
			</div>
		} else {
			<div id="explore-items" class="explore-results feed-grid" data-feed-masonry data-masonry-card=".explore-card">
				for _, item := range props.Result.Items {
					@ExploreCard(item, props.Result.Documents[item.SubjectURI], props.RoutePaths)
				}
			</div>
			@ExploreMoreRow(props, false)
		}
	</div>
}

templ ExploreAppend(props ExploreProps) {
	for _, item := range props.Result.Items {
		@ExploreCard(item, props.Result.Documents[item.SubjectURI], props.RoutePaths)
	}
	@ExploreMoreRow(props, true)
}

templ ExploreMoreRow(props ExploreProps, oob bool) {
	if oob {
		<div id="explore-more-row" class="explore-more-row" hx-swap-oob="outerHTML">
			@exploreMoreLink(props)
		</div>
	} else {
		<div id="explore-more-row" class="explore-more-row">
			@exploreMoreLink(props)
		</div>
	}
}

templ exploreMoreLink(props ExploreProps) {
	if props.Result != nil && props.Result.NextCursor != "" {
		<a class="btn-secondary inline-flex" href={ templ.SafeURL(nextExploreURL(props)) } hx-get={ templ.SafeURL(nextExploreURL(props)) } hx-target="#explore-items" hx-swap="beforeend">More results</a>
	}
}

templ typeOption(selected lexicons.RecordType, value lexicons.RecordType, label string) {
	<option value={ string(value) } selected?={ selected == value }>{ label }</option>
}

templ filterInput(props ExploreProps, name string, label string, placeholder string) {
	<label class="block">
		<span class="block text-sm font-medium text-muted mb-1">{ label }</span>
		<input class="form-input w-full" type="text" name={ name } value={ selectedFilter(props, name) } placeholder={ placeholder }/>
	</label>
}

templ ExploreCard(item *feed.FeedItem, doc firehose.ExploreDocument, routePaths map[lexicons.RecordType]string) {
	<article class="explore-card" data-kind={ exploreKind(item.RecordType) }>
		<div class="explore-card-head">
			@components.AuthorByline(item.Author, doc.DID)
			@components.TypeBadge(string(item.RecordType))
		</div>
		<a href={ templ.SafeURL(exploreItemURL(item, routePaths)) } class="explore-card-link">
			@exploreItemContent(item)
		</a>
		<div class="explore-card-stats">
			if doc.OwnRating.Valid {
				<span class="explore-stat explore-stat-rating">
					@components.IconStar()
					{ fmt.Sprintf("%.0f/10", doc.OwnRating.Float64) }
				</span>
			}
			<span>{ fmt.Sprintf("%d likes", item.LikeCount) }</span>
			<span>{ fmt.Sprintf("%d comments", item.CommentCount) }</span>
			if doc.SourceRefCount > 0 {
				<span>{ fmt.Sprintf("used by %d", doc.SourceRefCount) }</span>
			}
			<time datetime={ doc.CreatedAt.Format("2006-01-02T15:04:05Z07:00") }>{ doc.CreatedAt.Format("Jan 2, 2006") }</time>
		</div>
	</article>
}

templ exploreItemContent(item *feed.FeedItem) {
	switch item.RecordType {
		case lexicons.RecordTypeBean:
			@coffeecomponents.BeanFeedContent(item)
		case lexicons.RecordTypeRoaster:
			@coffeecomponents.RoasterFeedContent(item)
		case lexicons.RecordTypeGrinder:
			@coffeecomponents.GrinderFeedContent(item)
		case lexicons.RecordTypeBrewer:
			@coffeecomponents.BrewerFeedContent(item)
		case lexicons.RecordTypeRecipe:
			@coffeecomponents.FeedRecipeContent(item)
	}
}

func selectedFilter(props ExploreProps, name string) string {
	if props.Query.Filters == nil {
		return ""
	}
	return props.Query.Filters[name]
}

func hasExploreControls(props ExploreProps) bool {
	return props.Query.Q != "" || props.Query.Type != "" || (props.Query.Sort != "" && props.Query.Sort != "recent") || hasAdvancedFilters(props)
}

func exploreKind(recordType lexicons.RecordType) string {
	switch recordType {
	case lexicons.RecordTypeBean:
		return "bean"
	case lexicons.RecordTypeRoaster:
		return "roaster"
	case lexicons.RecordTypeGrinder:
		return "grinder"
	case lexicons.RecordTypeBrewer:
		return "brewer"
	case lexicons.RecordTypeRecipe:
		return "recipe"
	default:
		return "bean"
	}
}

func hasAdvancedFilters(props ExploreProps) bool {
	for _, val := range props.Query.Filters {
		if val != "" {
			return true
		}
	}
	return false
}

func exploreActiveLabel(props ExploreProps) string {
	count := 0
	if props.Query.Q != "" {
		count++
	}
	if props.Query.Type != "" {
		count++
	}
	if props.Query.Sort != "" && props.Query.Sort != "recent" {
		count++
	}
	for _, val := range props.Query.Filters {
		if val != "" {
			count++
		}
	}
	if count == 0 {
		return "No filters"
	}
	return fmt.Sprintf("%d active", count)
}

func exploreItemURL(item *feed.FeedItem, routePaths map[lexicons.RecordType]string) string {
	if item == nil {
		return "/explore"
	}
	if path := routePaths[item.RecordType]; path != "" && item.RKey() != "" {
		actor := ""
		if item.Author != nil && item.Author.Handle != "" {
			actor = item.Author.Handle
		} else if item.Author != nil {
			actor = item.Author.DID
		}
		return fmt.Sprintf("/%s/%s/%s", path, actor, item.RKey())
	}
	return "/explore"
}

func nextExploreURL(props ExploreProps) string {
	v := url.Values{}
	if props.Query.Type != "" {
		v.Set("type", string(props.Query.Type))
	}
	if props.Query.Q != "" {
		v.Set("q", props.Query.Q)
	}
	if props.Query.Sort != "" {
		v.Set("sort", props.Query.Sort)
	}
	for k, val := range props.Query.Filters {
		if val != "" {
			v.Set(k, val)
		}
	}
	if props.Result != nil && props.Result.NextCursor != "" {
		v.Set("cursor", props.Result.NextCursor)
	}
	return "/explore?" + v.Encode()
}
