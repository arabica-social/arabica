package tea

import (
	"fmt"

	"tangled.org/arabica.social/arabica/internal/entities"
	"tangled.org/arabica.social/arabica/internal/entities/oolong"
	"tangled.org/arabica.social/arabica/internal/feed"
)

// feedItemShareURL builds the share/view URL for an oolong feed item.
// Mirrors arabica's helper of the same name.
func feedItemShareURL(item *feed.FeedItem) string {
	if d := entities.Get(item.RecordType); d != nil {
		if rkey := item.RKey(); rkey != "" {
			return fmt.Sprintf("/%s/%s/%s", d.URLPath, feedActor(item), rkey)
		}
	}
	return fmt.Sprintf("/profile/%s", item.Author.DID)
}

// feedActor returns the handle when known, falling back to the DID. Used to
// build the {actor} segment of /{slug}/{actor}/{rkey} URLs from feed items.
func feedActor(item *feed.FeedItem) string {
	if item.Author.Handle != "" {
		return item.Author.Handle
	}
	return item.Author.DID
}

templ TeaFeedContent(item *feed.FeedItem) {
	if t, ok := item.Record.(*oolong.Tea); ok && t != nil {
		<a href={ templ.SafeURL(feedItemShareURL(item)) } class="block hover:opacity-90 transition-opacity">
			@TeaContent(t)
		</a>
	}
}

templ VendorFeedContent(item *feed.FeedItem) {
	if v, ok := item.Record.(*oolong.Vendor); ok && v != nil {
		<a href={ templ.SafeURL(feedItemShareURL(item)) } class="block hover:opacity-90 transition-opacity">
