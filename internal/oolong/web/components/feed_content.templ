templ BrewFeedContent(item *feed.FeedItem) {
	if b, ok := item.Record.(*oolong.Brew); ok && b != nil {
		<a href={ templ.SafeURL(fmt.Sprintf("/brews/%s/%s", feedActor(item), b.RKey)) } class="block hover:opacity-90 transition-opacity">
			@BrewContent(b)
		</a>
	}
}
