// Dialog modals for the 7 oolong entities. Each wraps ModalShell — which
// owns the <dialog> chrome, hx-post/hx-put dispatch, error banner, and
// Save/Cancel buttons — and supplies entity-specific form inputs as
// children. Field name="X" attributes match each request struct's
// `json:"X"` tag so the form-decoding reflection helper in
// internal/handlers/oolong_crud.go can populate the request struct
// without per-entity FormValue() boilerplate.
//
// These are intentionally simpler than arabica's BeanDialogModal et al.
// — no entity suggestions, no autocomplete, no dynamic visibility — to
// keep the first oolong CRUD surface small and reviewable. Polish
// (suggestions, combo-select for refs, etc.) lands in a follow-up.

func teaRKey(t *oolong.Tea) string {
	if t == nil {
		return ""
	}
	return t.RKey
}

func vendorRKey(v *oolong.Vendor) string {
	if v == nil {
		return ""
	}
	return v.RKey
}

func teaBrewerRKey(b *oolong.Brewer) string {
	if b == nil {
		return ""
	}
	return b.RKey
}

func teaRecipeRKey(r *oolong.Recipe) string {
	if r == nil {
		return ""
	}
	return r.RKey
}

func teaBrewRKey(b *oolong.Brew) string {
	if b == nil {
		return ""
	}
	return b.RKey
}

func cafeRKey(c *oolong.Cafe) string {
	if c == nil {
		return ""
	}
	return c.RKey
}

func drinkRKey(d *oolong.Drink) string {
	if d == nil {
		return ""
	}
	return d.RKey
}

func intStrOrEmpty(n int) string {
	if n == 0 {
		return ""
	}
	return strconv.Itoa(n)
}

func floatStrOrEmpty(n float64) string {
	if n == 0 {
		return ""
	}
	return fmt.Sprintf("%g", n)
}

func ratingStr(r *int) string {
	if r == nil {
		return ""
	}
	return strconv.Itoa(*r)
}

// comboSelectField renders a labelled combo-select inside a dialog
// modal. selectedRKey + selectedLabel pre-populate the field on edit.
// label is the visible field label, sectionLabel is the heading shown
// above the user's own records in the dropdown. required toggles the
// asterisk and the underlying combo-select required flag.
templ comboSelectField(entityType, apiEndpoint, suggestEndpoint, inputName, placeholder, label, sectionLabel, selectedRKey, selectedLabel string, required bool) {
	<div
		class="combo-select"
		x-data={ ComboSelectConfig(entityType, apiEndpoint, suggestEndpoint, inputName, placeholder, required) }
		if selectedRKey != "" {
			x-init={ fmt.Sprintf("selectedRKey = '%s'; query = '%s'; selectedLabel = query", selectedRKey, EscapeJS(selectedLabel)) }
		}
	>
		<label class="form-label">
			{ label }
			if required {
				<span class="text-red-600">*</span>
			}
		</label>
		<input type="hidden" :name="inputName" :value="selectedRKey"/>
		@ComboSelectInput(sectionLabel)
	</div>
}

// labelTea returns a human-readable label for a Tea (name + category/origin),
// used to pre-populate combo-select fields on edit modals.
func labelTea(t *oolong.Tea) string {
	if t == nil {
		return ""
	}
	name := t.Name
	if name == "" {
		name = t.RKey
	}
	switch {
	case t.Category != "" && t.Origin != "":
		return name + " (" + t.Category + " · " + t.Origin + ")"
	case t.Category != "":
		return name + " (" + t.Category + ")"
	case t.Origin != "":
		return name + " (" + t.Origin + ")"
	}
	return name
}

func labelOolongBrewer(b *oolong.Brewer) string {
	if b == nil {
		return ""
	}
	name := b.Name
	if name == "" {
		name = b.RKey
	}
	if b.Style != "" {
		return name + " (" + b.Style + ")"
	}
	return name
}

func labelOolongRecipe(r *oolong.Recipe) string {
	if r == nil {
		return ""
	}
	name := r.Name
	if name == "" {
		name = r.RKey
	}
	if r.Style != "" {
		return name + " (" + r.Style + ")"
	}
	return name
}

func labelOolongVendor(v *oolong.Vendor) string {
	if v == nil {
		return ""
	}
	name := v.Name
	if name == "" {
		name = v.RKey
	}
	if v.Location != "" {
		return name + " (" + v.Location + ")"
	}
	return name
}

// brewTea returns the Tea joined onto the Brew, or a synthetic Tea
// holding just the referenced RKey so combo-selects on edit modals can
// show the rkey as fallback label when reference resolution didn't
// run.
func brewTea(b *oolong.Brew) *oolong.Tea {
	if b == nil {
		return nil
	}
	if b.Tea != nil {
		return b.Tea
	}
	if b.TeaRKey == "" {
		return nil
	}
	return &oolong.Tea{RKey: b.TeaRKey}
}

func brewBrewer(b *oolong.Brew) *oolong.Brewer {
	if b == nil {
		return nil
	}
	if b.BrewerObj != nil {
		return b.BrewerObj
	}
	if b.BrewerRKey == "" {
		return nil
	}
	return &oolong.Brewer{RKey: b.BrewerRKey}
}

func brewRecipe(b *oolong.Brew) *oolong.Recipe {
	if b == nil {
		return nil
	}
	if b.RecipeObj != nil {
		return b.RecipeObj
	}
	if b.RecipeRKey == "" {
		return nil
	}
	return &oolong.Recipe{RKey: b.RecipeRKey}
}

func recipeTea(r *oolong.Recipe) *oolong.Tea {
	if r == nil {
		return nil
	}
	if r.Tea != nil {
		return r.Tea
	}
	if r.TeaRKey == "" {
		return nil
	}
	return &oolong.Tea{RKey: r.TeaRKey}
}

func recipeBrewer(r *oolong.Recipe) *oolong.Brewer {
	if r == nil {
		return nil
	}
	if r.BrewerObj != nil {
		return r.BrewerObj
