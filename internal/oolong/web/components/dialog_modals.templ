// --- Vendor ----------------------------------------------------------
templ VendorDialogModal(v *oolong.Vendor) {
	@ModalShell(ModalShellProps{
		Type: lexicons.RecordTypeOolongVendor,
		RKey: vendorRKey(v),
	}) {
		<div class="form-fieldset">
			<div class="form-fieldset-label">Essentials</div>
			<input type="text" name="name" placeholder="Vendor name *" required class="w-full form-input" value={ vendorField(v, func(v *oolong.Vendor) string { return v.Name }) }/>
			<input type="text" name="location" placeholder="Location" class="w-full form-input" value={ vendorField(v, func(v *oolong.Vendor) string { return v.Location }) }/>
			<input type="url" name="website" placeholder="Website" class="w-full form-input" value={ vendorField(v, func(v *oolong.Vendor) string { return v.Website }) }/>
		</div>
		<div class="form-divider"></div>
		<div class="form-fieldset">
			<div class="form-fieldset-label">Notes <span class="form-optional-hint">(optional)</span></div>
			<textarea name="description" placeholder="Description" class="w-full form-input" rows="3">{ vendorField(v, func(v *oolong.Vendor) string { return v.Description }) }</textarea>
		</div>
	}
}

func vendorField(v *oolong.Vendor, fn func(*oolong.Vendor) string) string {
	if v == nil {
		return ""
	}
	return fn(v)
}

// --- Brewer (teaware) ------------------------------------------------
templ BrewerDialogModal(b *oolong.Brewer) {
	@ModalShell(ModalShellProps{
		Type: lexicons.RecordTypeOolongBrewer,
		RKey: teaBrewerRKey(b),
	}) {
		<div class="form-fieldset">
			<div class="form-fieldset-label">Essentials</div>
			<input type="text" name="name" placeholder="Name *" required class="w-full form-input" value={ teaBrewerField(b, func(b *oolong.Brewer) string { return b.Name }) }/>
			<input type="text" name="style" placeholder="Style (e.g. teapot, infuser, matcha-bowl)" class="w-full form-input" value={ teaBrewerField(b, func(b *oolong.Brewer) string { return b.Style }) }/>
		</div>
		<div class="form-divider"></div>
		<div class="form-fieldset">
			<div class="form-fieldset-label">Details <span class="form-optional-hint">(optional)</span></div>
			<input type="number" name="capacity_ml" placeholder="Capacity (ml)" class="w-full form-input" value={ teaBrewerField(b, func(b *oolong.Brewer) string { return intStrOrEmpty(b.CapacityMl) }) }/>
			<input type="text" name="material" placeholder="Material (e.g. porcelain, clay, glass)" class="w-full form-input" value={ teaBrewerField(b, func(b *oolong.Brewer) string { return b.Material }) }/>
			<textarea name="description" placeholder="Notes" class="w-full form-input" rows="3">{ teaBrewerField(b, func(b *oolong.Brewer) string { return b.Description }) }</textarea>
		</div>
	}
}

func teaBrewerField(b *oolong.Brewer, fn func(*oolong.Brewer) string) string {
	if b == nil {
		return ""
	}
	return fn(b)
}

// --- Recipe ----------------------------------------------------------
templ RecipeDialogModal(r *oolong.Recipe) {
	@ModalShell(ModalShellProps{
		Type: lexicons.RecordTypeOolongRecipe,
		RKey: teaRecipeRKey(r),
	}) {
		<div class="form-fieldset">
			<div class="form-fieldset-label">Essentials</div>
			<input type="text" name="name" placeholder="Recipe name *" required class="w-full form-input" value={ teaRecipeField(r, func(r *oolong.Recipe) string { return r.Name }) }/>
			<input type="text" name="style" placeholder="Style (e.g. gongfu, western)" class="w-full form-input" value={ teaRecipeField(r, func(r *oolong.Recipe) string { return r.Style }) }/>
		</div>
		<div class="form-divider"></div>
		<div class="form-fieldset">
			<div class="form-fieldset-label">References <span class="form-optional-hint">(optional)</span></div>
			@comboSelectField(
				"tea", "/api/teas", "/api/suggestions/teas", "tea_rkey",
				"Search or create a tea…", "Tea", "Your teas",
				teaRecipeField(r, func(r *oolong.Recipe) string { return r.TeaRKey }),
				labelTea(recipeTea(r)), false,
			)
			@comboSelectField(
				"oolongBrewer", "/api/brewers", "/api/suggestions/brewers", "brewer_rkey",
				"Search or create a brewer…", "Brewer", "Your brewers",
				teaRecipeField(r, func(r *oolong.Recipe) string { return r.BrewerRKey }),
				labelOolongBrewer(recipeBrewer(r)), false,
			)
		</div>
		<div class="form-divider"></div>
		<div class="form-fieldset">
			<div class="form-fieldset-label">Parameters</div>
			<input type="number" name="leaf_grams" step="0.1" placeholder="Leaf (g)" class="w-full form-input" value={ teaRecipeField(r, func(r *oolong.Recipe) string { return floatStrOrEmpty(r.LeafGrams) }) }/>
			<input type="number" name="vessel_ml" placeholder="Vessel (ml)" class="w-full form-input" value={ teaRecipeField(r, func(r *oolong.Recipe) string { return intStrOrEmpty(r.VesselMl) }) }/>
			<input type="number" name="temperature" step="0.1" placeholder="Temperature (°C)" class="w-full form-input" value={ teaRecipeField(r, func(r *oolong.Recipe) string { return floatStrOrEmpty(r.Temperature) }) }/>
			<input type="number" name="time_seconds" placeholder="Time (s)" class="w-full form-input" value={ teaRecipeField(r, func(r *oolong.Recipe) string { return intStrOrEmpty(r.TimeSeconds) }) }/>
		</div>
		<div class="form-divider"></div>
		<div class="form-fieldset">
			<div class="form-fieldset-label">Notes <span class="form-optional-hint">(optional)</span></div>
			<textarea name="notes" placeholder="Notes" class="w-full form-input" rows="3">{ teaRecipeField(r, func(r *oolong.Recipe) string { return r.Notes }) }</textarea>
		</div>
	}
}

func teaRecipeField(r *oolong.Recipe, fn func(*oolong.Recipe) string) string {
	if r == nil {
		return ""
	}
	return fn(r)
}

// --- Brew (steep) ----------------------------------------------------
templ BrewDialogModal(b *oolong.Brew) {
	@ModalShell(ModalShellProps{
		Type: lexicons.RecordTypeOolongBrew,
		RKey: teaBrewRKey(b),
	}) {
		<div class="form-fieldset">
			<div class="form-fieldset-label">Essentials</div>
			@comboSelectField(
				"tea", "/api/teas", "/api/suggestions/teas", "tea_rkey",
				"Search or create a tea…", "Tea", "Your teas",
				teaBrewField(b, func(b *oolong.Brew) string { return b.TeaRKey }),
				labelTea(brewTea(b)), true,
			)
			<input type="text" name="style" placeholder="Style (e.g. longSteep, coldBrew)" class="w-full form-input" value={ teaBrewField(b, func(b *oolong.Brew) string { return b.Style }) }/>
		</div>
		<div class="form-divider"></div>
		<div class="form-fieldset">
			<div class="form-fieldset-label">References <span class="form-optional-hint">(optional)</span></div>
			@comboSelectField(
				"oolongBrewer", "/api/brewers", "/api/suggestions/brewers", "brewer_rkey",
				"Search or create a brewer…", "Brewer", "Your brewers",
				teaBrewField(b, func(b *oolong.Brew) string { return b.BrewerRKey }),
				labelOolongBrewer(brewBrewer(b)), false,
			)
		</div>
		<div class="form-divider"></div>
		<div class="form-fieldset">
			<div class="form-fieldset-label">Parameters</div>
			<input type="number" name="leaf_grams" step="0.1" placeholder="Leaf (g)" class="w-full form-input" value={ teaBrewField(b, func(b *oolong.Brew) string { return floatStrOrEmpty(b.LeafGrams) }) }/>
			<input type="number" name="vessel_ml" placeholder="Water (g/ml)" class="w-full form-input" value={ teaBrewField(b, func(b *oolong.Brew) string { return intStrOrEmpty(b.VesselMl) }) }/>
			<input type="number" name="temperature" step="0.1" placeholder="Temperature (°C)" class="w-full form-input" value={ teaBrewField(b, func(b *oolong.Brew) string { return floatStrOrEmpty(b.Temperature) }) }/>
			<input type="number" name="time_seconds" placeholder="Time (s)" class="w-full form-input" value={ teaBrewField(b, func(b *oolong.Brew) string { return intStrOrEmpty(b.TimeSeconds) }) }/>
		</div>
		<div class="form-divider"></div>
		<div class="form-fieldset">
			<div class="form-fieldset-label">Tasting</div>
			<textarea name="tasting_notes" placeholder="Tasting notes" class="w-full form-input" rows="3">{ teaBrewField(b, func(b *oolong.Brew) string { return b.TastingNotes }) }</textarea>
			<input type="number" name="rating" min="1" max="10" placeholder="Rating (1-10)" class="w-full form-input" value={ teaBrewField(b, func(b *oolong.Brew) string { return intStrOrEmpty(b.Rating) }) }/>
		</div>
	}
}

func teaBrewField(b *oolong.Brew, fn func(*oolong.Brew) string) string {
	if b == nil {
		return ""
	}
	return fn(b)
}

// --- Cafe ------------------------------------------------------------
templ CafeDialogModal(c *oolong.Cafe) {
	@ModalShell(ModalShellProps{
		Type: lexicons.RecordTypeOolongCafe,
		RKey: cafeRKey(c),
	}) {
		<div class="form-fieldset">
			<div class="form-fieldset-label">Essentials</div>
			<input type="text" name="name" placeholder="Cafe name *" required class="w-full form-input" value={ cafeField(c, func(c *oolong.Cafe) string { return c.Name }) }/>
			<input type="text" name="location" placeholder="City / neighborhood" class="w-full form-input" value={ cafeField(c, func(c *oolong.Cafe) string { return c.Location }) }/>
			<input type="text" name="address" placeholder="Street address" class="w-full form-input" value={ cafeField(c, func(c *oolong.Cafe) string { return c.Address }) }/>
			<input type="url" name="website" placeholder="Website" class="w-full form-input" value={ cafeField(c, func(c *oolong.Cafe) string { return c.Website }) }/>
		</div>
		<div class="form-divider"></div>
		<div class="form-fieldset">
			<div class="form-fieldset-label">Details <span class="form-optional-hint">(optional)</span></div>
			@comboSelectField(
				"vendor", "/api/vendors", "/api/suggestions/vendors", "vendor_rkey",
				"Search or create a vendor…", "Vendor", "Your vendors",
				cafeField(c, func(c *oolong.Cafe) string { return c.VendorRKey }),
				labelOolongVendor(cafeVendor(c)), false,
			)
			<textarea name="description" placeholder="Description" class="w-full form-input" rows="3">{ cafeField(c, func(c *oolong.Cafe) string { return c.Description }) }</textarea>
		</div>
	}
}

func cafeField(c *oolong.Cafe, fn func(*oolong.Cafe) string) string {
	if c == nil {
		return ""
	}
	return fn(c)
}

