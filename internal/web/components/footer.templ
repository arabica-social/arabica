package components

// footerBrandName returns the brand name with the arabica fallback so
// existing @Footer() call sites without threaded brand still render.
func footerBrandName(name string) string {
	if name != "" {
		return name
	}
	return "Arabica"
}

func footerTagline(tagline string) string {
	if tagline != "" {
		return tagline
	}
	return "Your brew, your data"
}

templ Footer() {
	@FooterWithBrand("", "")
}

// FooterWithBrand renders the footer with the configured brand name and
// tagline. Empty values fall back to arabica defaults.
templ FooterWithBrand(brandName, tagline string) {
	<footer class="mt-auto" style="background: var(--footer-bg); border-top: 1px solid var(--footer-border);">
		<div class="container mx-auto px-4 py-8">
			<div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
				<div class="text-sm text-emphasis">
					<span class="font-semibold text-primary">{ footerBrandName(brandName) }</span> - { footerTagline(tagline) }
				</div>
				<nav class="flex flex-wrap justify-center gap-6 text-sm">
					<a href="/about" class="text-emphasis hover:text-primary transition-colors">About</a>
					<a href="/terms" class="text-emphasis hover:text-primary transition-colors">Terms of Service</a>
					<a href="https://tangled.org/arabica.social/arabica" target="_blank" rel="noopener noreferrer" class="text-emphasis hover:text-primary transition-colors">Source Code</a>
					<a href="/atproto" class="text-emphasis hover:text-primary transition-colors">AT Protocol</a>
					<a href="/about#support" class="text-emphasis hover:text-primary transition-colors">Support</a>
				</nav>
			</div>
		</div>
	</footer>
}
