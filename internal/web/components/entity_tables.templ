// RecipesTableProps defines props for the shared recipes display
type RecipesTableProps struct {
	Recipes     []*models.Recipe
	ShowActions bool
}

// RecipesTable renders a grid of recipe cards
templ RecipesTable(props RecipesTableProps) {
	if len(props.Recipes) == 0 {
		@EmptyState(EmptyStateProps{Message: "No recipes yet."})
	} else {
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
			for _, recipe := range props.Recipes {
				@RecipeCard(recipe, props.ShowActions)
			}
		</div>
	}
}

// RecipeCard renders a single recipe as a compact card
templ RecipeCard(recipe *models.Recipe, showActions bool) {
	<div class="feed-card feed-card-recipe">
		@entityCardHeader(recipe.CreatedAt, showActions, "/api/modals/recipe/"+recipe.RKey, "/api/recipes/"+recipe.RKey, "recipe")
		<div class="feed-content-box-sm">
			<div class="flex items-start justify-between gap-2 mb-2">
				<div class="min-w-0">
					<div class="font-bold text-brown-900 text-base truncate"><a href={ templ.SafeURL(fmt.Sprintf("/recipes/%s", recipe.RKey)) } class="hover:underline">{ recipe.Name }</a></div>
					if recipe.BrewerObj != nil {
						<div class="text-sm text-brown-700 mt-0.5">
							<span class="font-medium inline-flex items-center gap-1">
								@IconBrewer()
								{ recipe.BrewerObj.Name }
							</span>
						</div>
					} else if recipe.BrewerType != "" {
						<div class="text-sm text-brown-700 mt-0.5">
							<span class="font-medium inline-flex items-center gap-1">
								@IconBrewer()
								{ recipe.BrewerType }
							</span>
						</div>
					}
				</div>
			</div>
			<div class="text-xs text-brown-600 mt-1 flex flex-wrap gap-x-2 gap-y-1">
				if recipe.CoffeeAmount > 0 {
					<span class="inline-flex items-center gap-1">
						@IconScale()
						{ fmt.Sprintf("%.1fg coffee", recipe.CoffeeAmount) }
					</span>
				}
				if recipe.WaterAmount > 0 {
					<span class="inline-flex items-center gap-1">
						@IconDroplet()
						{ fmt.Sprintf("%.1fg water", recipe.WaterAmount) }
					</span>
				}
			</div>
		</div>
	</div>
}
