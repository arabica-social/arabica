package components

import "tangled.org/arabica.social/arabica/internal/entities/arabica"

// BeanContent renders bean details inside a card
templ BeanContent(bean *arabica.Bean) {
	<div class="feed-content-box-sm">
		@BeanSummary(BeanSummaryProps{
			Bean: bean,
		})
		if bean.Description != "" {
			<div class="mt-2 text-sm text-brown-800 italic">"{ bean.Description }"</div>
		}
	</div>
}
