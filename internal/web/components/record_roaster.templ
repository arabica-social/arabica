package components

import (
	"tangled.org/arabica.social/arabica/internal/entities/arabica"
	"tangled.org/arabica.social/arabica/internal/web/bff"
)

// RoasterContent renders roaster details inside a card
templ RoasterContent(roaster *arabica.Roaster) {
	<div class="feed-content-box-sm">
		<div class="text-base mb-2">
			<span class="font-bold text-primary">{ roaster.Name }</span>
		</div>
		<div class="text-xs text-muted mt-1 flex flex-wrap gap-x-2 gap-y-1">
			if roaster.Location != "" {
				<span class="inline-flex items-center gap-1">
					@IconMapPin()
					{ roaster.Location }
				</span>
			}
			if roaster.Website != "" {
				if safeWebsite := bff.SafeWebsiteURL(roaster.Website); safeWebsite != "" {
					<span class="inline-flex items-center gap-1">
						@IconGlobe()
						<a href={ templ.SafeURL(safeWebsite) } target="_blank" rel="noopener noreferrer" class="text-secondary hover:underline">{ safeWebsite }</a>
					</span>
				}
			}
		</div>
	</div>
}
