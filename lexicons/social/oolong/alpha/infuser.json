{
  "lexicon": 1,
  "id": "social.oolong.alpha.infuser",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "description": "A standalone infuser used inside a vessel to contain loose leaf during brewing (basket, ball, sock, etc.). Tea bags and loose-leaf-in-vessel are not infusers — they are infusion methods on the brew record.",
      "record": {
        "type": "object",
        "required": ["name", "createdAt"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 200,
            "description": "Name of the infuser (e.g., 'stainless basket', 'silicone tea ball', 'cotton sock')"
          },
          "style": {
            "type": "string",
            "maxLength": 50,
            "knownValues": [
              "basket", "ball", "sock", "other"
            ],
            "description": "Infuser form-factor. Known values: basket, ball, sock, other"
          },
          "material": {
            "type": "string",
            "maxLength": 200,
            "description": "Material (e.g., 'stainless steel', 'silicone', 'cotton', 'paper')"
          },
          "description": {
            "type": "string",
            "maxLength": 1000
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "sourceRef": {
            "type": "string",
            "format": "at-uri"
          }
        }
      }
    }
  }
}
