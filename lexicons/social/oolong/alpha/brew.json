{
  "lexicon": 1,
  "id": "social.oolong.alpha.brew",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "description": "A tea brewing session",
      "record": {
        "type": "object",
        "required": ["teaRef", "style", "createdAt"],
        "properties": {
          "teaRef": {
            "type": "string",
            "format": "at-uri",
            "description": "AT-URI to a social.oolong.alpha.tea record"
          },
          "style": {
            "type": "string",
            "maxLength": 50,
            "knownValues": ["longSteep", "coldBrew"],
            "description": "Brewing style. Required. Canonical filterable axis."
          },
          "vesselRef": {
            "type": "string",
            "format": "at-uri",
            "description": "AT-URI to a social.oolong.alpha.brewer record"
          },
          "infusionMethod": {
            "type": "string",
            "maxLength": 50,
            "knownValues": ["tea-bag", "loose-leaf", "infuser"],
            "description": "How the leaf was contained during brewing"
          },
          "infuserRef": {
            "type": "string",
            "format": "at-uri",
            "description": "AT-URI to a social.oolong.alpha.infuser record. Only meaningful when infusionMethod=infuser."
          },
          "temperature": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000,
            "description": "Water temperature in tenths of °C (e.g. 850 = 85.0°C)"
          },
          "leafGrams": {
            "type": "integer",
            "minimum": 0,
            "description": "Leaf weight in tenths of a gram (e.g. 50 = 5.0g)"
          },
          "waterAmount": {
            "type": "integer",
            "minimum": 0,
            "description": "Amount of water used in grams or milliliters"
          },
          "timeSeconds": {
            "type": "integer",
            "minimum": 0,
            "description": "Total brew time in seconds"
          },
          "tastingNotes": {
            "type": "string",
            "maxLength": 2000
          },
          "rating": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
